{
	"compileOnSave": false,
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext"],
		"allowJs": true,
		"module": "nodenext",
		"rootDir": "./src",
		"outDir": "./dist",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "nodenext",
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"typeRoots": ["./src/types", "./node_modules/@types"],
		"sourceMap": true,
		"types": ["node", "express"],
		"noImplicitAny": false,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}